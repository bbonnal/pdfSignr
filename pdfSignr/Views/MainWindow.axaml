<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:pdfSignr.ViewModels"
        xmlns:views="using:pdfSignr.Views"
        xmlns:iconr="using:Iconr.Markup"
        x:Class="pdfSignr.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="pdfSignr"
        Icon="avares://pdfSignr/Assets/signature_icon.ico"
        Width="900" Height="700"
        WindowStartupLocation="CenterScreen">

  <Panel DragDrop.AllowDrop="True">
    <DockPanel>

      <!-- ═══ Left icon toolbar ═══ -->
      <Border DockPanel.Dock="Left" Width="46"
              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
              BorderThickness="0,0,1,0">
        <DockPanel Margin="3,6,3,6">

          <StackPanel DockPanel.Dock="Top" Spacing="2" HorizontalAlignment="Center">
            <Button Classes="icon-btn" Command="{Binding OpenCommand}" ToolTip.Tip="Open PDF (Ctrl+O)">
              <PathIcon Data="{iconr:IconGeometry Icon=folder_open}" Foreground="{DynamicResource IconForeground}" Width="20" Height="20" />
            </Button>
            <Button Classes="icon-btn" ToolTip.Tip="Save (Ctrl+S)">
              <Button.Flyout>
                <Flyout Placement="Right">
                  <StackPanel Width="200" Spacing="6">
                    <Button Classes="flyout-btn" Content="Save all pages"
                            Command="{Binding SaveCommand}" />
                    <Button Classes="flyout-btn" Content="Save selected pages"
                            Command="{Binding SaveSelectedPagesCommand}"
                            IsVisible="{Binding HasSelectedPages}" />
                    <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Margin="0,2" />
                    <TextBlock Text="Save page range" FontSize="11" FontWeight="SemiBold" Opacity="0.6" />
                    <TextBox x:Name="SaveRangeBox" PlaceholderText="e.g. 1-5" FontSize="12" />
                    <Button Classes="flyout-btn" Content="Save range"
                            x:Name="SaveRangeBtn" Click="OnSaveRangeClick" />
                    <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Margin="0,4" />
                    <CheckBox x:Name="LockOnSaveCheck" Content="Lock with password" FontSize="12"
                              IsChecked="{Binding LockOnSave}" />
                  </StackPanel>
                </Flyout>
              </Button.Flyout>
              <PathIcon Data="{iconr:IconGeometry Icon=floppy_disk}" Foreground="{DynamicResource IconForeground}" Width="20" Height="20" />
            </Button>
            <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Margin="2,5" />
            <Button Classes="icon-btn" Command="{Binding UndoCommand}" ToolTip.Tip="Undo (Ctrl+Z)">
              <PathIcon Data="{iconr:IconGeometry Icon=arrow_counter_clockwise}" Foreground="{DynamicResource IconForeground}" Width="20" Height="20" />
            </Button>
            <Button Classes="icon-btn" Command="{Binding RedoCommand}" ToolTip.Tip="Redo (Ctrl+Y)">
              <PathIcon Data="{iconr:IconGeometry Icon=arrow_clockwise}" Foreground="{DynamicResource IconForeground}" Width="20" Height="20" />
            </Button>
            <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Margin="2,5" />
            <Button Classes="icon-btn" ToolTip.Tip="Compress / Rasterize PDF">
              <Button.Flyout>
                <Flyout Placement="Right">
                  <StackPanel Width="180" Spacing="4">
                    <TextBlock Text="Resample images" FontSize="11" FontWeight="SemiBold" Opacity="0.6" Margin="0,0,0,2" />
                    <Button Classes="flyout-btn" Content="Screen (smallest)"
                            Command="{Binding CompressResampleCommand}" CommandParameter="Screen" />
                    <Button Classes="flyout-btn" Content="Ebook (balanced)"
                            Command="{Binding CompressResampleCommand}" CommandParameter="Ebook" />
                    <Button Classes="flyout-btn" Content="Print (best quality)"
                            Command="{Binding CompressResampleCommand}" CommandParameter="Print" />
                    <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Margin="0,4" />
                    <TextBlock Text="Flatten to images" FontSize="11" FontWeight="SemiBold" Opacity="0.6" Margin="0,0,0,2" />
                    <Button Classes="flyout-btn" Content="72 DPI (screen)"
                            Command="{Binding CompressRasterizeCommand}" CommandParameter="Screen" />
                    <Button Classes="flyout-btn" Content="150 DPI (ebook)"
                            Command="{Binding CompressRasterizeCommand}" CommandParameter="Ebook" />
                    <Button Classes="flyout-btn" Content="300 DPI (print)"
                            Command="{Binding CompressRasterizeCommand}" CommandParameter="Print" />
                  </StackPanel>
                </Flyout>
              </Button.Flyout>
              <PathIcon Data="{iconr:IconGeometry Icon=file_arrow_down}" Foreground="{DynamicResource IconForeground}" Width="20" Height="20" />
            </Button>
            <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Margin="2,5" />
            <ToggleButton Classes="icon-btn"
                IsChecked="{Binding IsTextToolActive, Mode=OneWay}"
                Command="{Binding ToggleTextToolCommand}" ToolTip.Tip="{Binding TextToolTip}">
              <PathIcon Data="{iconr:IconGeometry Icon=text_aa}" Foreground="{DynamicResource IconForeground}" Width="20" Height="20" />
            </ToggleButton>
            <ToggleButton Classes="icon-btn"
                IsChecked="{Binding IsSignToolActive, Mode=OneWay}"
                Command="{Binding ToggleSignToolCommand}" ToolTip.Tip="{Binding SignToolTip}">
              <PathIcon Data="{iconr:IconGeometry Icon=signature}" Foreground="{DynamicResource IconForeground}" Width="20" Height="20" />
            </ToggleButton>
          </StackPanel>

          <StackPanel DockPanel.Dock="Bottom" Spacing="2" HorizontalAlignment="Center">
            <Button Classes="icon-btn" ToolTip.Tip="Keyboard shortcuts">
              <Button.Flyout>
                <Flyout Placement="Right">
                  <StackPanel x:Name="KeyBindingsFlyout" Width="260" Spacing="2" />
                </Flyout>
              </Button.Flyout>
              <PathIcon Data="{iconr:IconGeometry Icon=question}" Foreground="{DynamicResource IconForeground}" Width="20" Height="20" />
            </Button>
            <Button Classes="icon-btn" x:Name="ThemeToggle"
                    Click="OnThemeToggle" ToolTip.Tip="Toggle dark/light mode">
              <PathIcon x:Name="ThemeIcon"
                     Data="{iconr:IconGeometry Icon=sun}"
                     Foreground="{DynamicResource IconForeground}" Width="20" Height="20" />
            </Button>
          </StackPanel>

          <Panel />
        </DockPanel>
      </Border>

      <!-- ═══ Status bar ═══ -->
      <Border DockPanel.Dock="Bottom"
              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
              BorderThickness="0,1,0,0" Padding="10,2">
        <DockPanel>
          <!-- Right: zoom controls -->
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4"
                      VerticalAlignment="Center">
            <Button Classes="statusbar-btn" x:Name="GridToggleBtn" Click="OnToggleGridMode"
                    ToolTip.Tip="Toggle grid / list view">
              <PathIcon x:Name="GridToggleIcon"
                        Data="{iconr:IconGeometry Icon=squares_four}"
                        Foreground="{DynamicResource IconForeground}" Width="15" Height="15" />
            </Button>
            <Border Width="1" Height="14" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Margin="2,0" />
            <Button Classes="statusbar-btn" Click="OnFitToWidth" ToolTip.Tip="Fit to width (Ctrl+0)">
              <PathIcon Data="{iconr:IconGeometry Icon=magnifying_glass}" Foreground="{DynamicResource IconForeground}" Width="15" Height="15" />
            </Button>
            <Button Classes="statusbar-btn" Click="OnZoomOut" ToolTip.Tip="Zoom out (Ctrl+-)">
              <PathIcon Data="{iconr:IconGeometry Icon=magnifying_glass_minus}" Foreground="{DynamicResource IconForeground}" Width="15" Height="15" />
            </Button>
            <Button Classes="statusbar-btn" Click="OnZoomIn" ToolTip.Tip="Zoom in (Ctrl++)">
              <PathIcon Data="{iconr:IconGeometry Icon=magnifying_glass_plus}" Foreground="{DynamicResource IconForeground}" Width="15" Height="15" />
            </Button>
          </StackPanel>
          <!-- Left: status text -->
          <TextBlock Text="{Binding StatusText}" FontSize="11" Opacity="0.6"
                     VerticalAlignment="Center" />
        </DockPanel>
      </Border>

      <!-- ═══ PDF viewer ═══ -->
      <Panel>
        <ScrollViewer x:Name="PdfScrollViewer"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource SystemControlPageBackgroundChromeMediumLowBrush}">
          <LayoutTransformControl x:Name="ZoomTransform">
            <ItemsControl ItemsSource="{Binding Pages}" Margin="0,16">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Vertical" Spacing="0" HorizontalAlignment="Center" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:PageItem">
                  <StackPanel Classes="page-item">

                    <!-- ═══ Insert zone BEFORE (list mode, first page only) ═══ -->
                    <Panel IsVisible="{Binding IsFirst}">
                      <LayoutTransformControl IsVisible="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).IsNotGridMode}">
                        <LayoutTransformControl.LayoutTransform>
                          <ScaleTransform
                              ScaleX="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).ButtonScale}"
                              ScaleY="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).ButtonScale}" />
                        </LayoutTransformControl.LayoutTransform>
                        <Panel Height="28" Margin="0,2">
                          <Button Classes="insert-btn"
                                  IsVisible="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).IsNotDragging}"
                                  Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).InsertPagesBeforeCommand}"
                                  CommandParameter="{Binding}"
                                  ToolTip.Tip="Insert pages before">
                            <PathIcon Data="{iconr:IconGeometry Icon=plus_circle}" Foreground="{DynamicResource IconForegroundMuted}" Width="16" Height="16" />
                          </Button>
                          <Border IsVisible="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).IsDraggingFile}"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="4,2">
                            <Rectangle StrokeDashArray="4,3"
                                       Stroke="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       StrokeThickness="1.5" RadiusX="4" RadiusY="4" />
                          </Border>
                          <Border IsVisible="{Binding IsDropTargetBefore}"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                  Background="{DynamicResource AccentOverlayBrush}" CornerRadius="4" Margin="4,2">
                            <Rectangle Stroke="{DynamicResource AccentBrush}" StrokeThickness="2"
                                       StrokeDashArray="4,3" RadiusX="4" RadiusY="4" />
                          </Border>
                        </Panel>
                      </LayoutTransformControl>
                    </Panel>

                    <!-- ═══ PAGE ROW (buttons + page + insert zones) ═══ -->
                    <Panel Background="Transparent">
                    <Panel.ContextMenu>
                      <ContextMenu>
                        <MenuItem Header="Rotate clockwise"
                                  Command="{Binding ParentVM.RotatePageCwCommand}"
                                  CommandParameter="{Binding}" />
                        <MenuItem Header="Rotate counter-clockwise"
                                  Command="{Binding ParentVM.RotatePageCcwCommand}"
                                  CommandParameter="{Binding}" />
                        <Separator />
                        <MenuItem Header="Move up"
                                  Command="{Binding ParentVM.MovePageUpCommand}"
                                  CommandParameter="{Binding}" />
                        <MenuItem Header="Move down"
                                  Command="{Binding ParentVM.MovePageDownCommand}"
                                  CommandParameter="{Binding}" />
                        <Separator />
                        <MenuItem Header="Insert pages before..."
                                  Command="{Binding ParentVM.InsertPagesBeforeCommand}"
                                  CommandParameter="{Binding}" />
                        <MenuItem Header="Insert pages after..."
                                  Command="{Binding ParentVM.InsertPagesAfterCommand}"
                                  CommandParameter="{Binding}" />
                        <Separator />
                        <MenuItem Header="Add text annotation"
                                  Command="{Binding ParentVM.ToggleTextToolCommand}" />
                        <MenuItem Header="Add signature"
                                  Command="{Binding ParentVM.ToggleSignToolCommand}" />
                        <Separator />
                        <MenuItem Header="Save page..."
                                  Command="{Binding ParentVM.SaveSelectedPagesCommand}" />
                        <MenuItem Header="Delete page"
                                  Command="{Binding ParentVM.DeleteSelectedPagesCommand}" />
                      </ContextMenu>
                    </Panel.ContextMenu>
                    <Grid Margin="4,6" HorizontalAlignment="Center">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>  <!-- C0: page -->
                        <ColumnDefinition Width="Auto"/>  <!-- C1: vertical insert-after (grid) -->
                      </Grid.ColumnDefinitions>

                      <!-- C0: Page -->
                      <Panel Grid.Column="0">
                        <!-- Invisible outer hit-test border for easier drag grabbing -->
                        <Border Classes="page-select-hit" Classes.selected="{Binding IsSelected}"
                                BorderBrush="Transparent" BorderThickness="14" Margin="-14"
                                IsHitTestVisible="True" Background="Transparent">
                        <!-- Visible selection border (the blue outline) -->
                        <Border Classes="page-select" Classes.selected="{Binding IsSelected}"
                                BorderThickness="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).SelectionBorderThickness}">
                        <Border BoxShadow="{DynamicResource PageShadow}" Background="{DynamicResource PageSurfaceBrush}">
                          <views:PageCanvas
                              PageBitmap="{Binding Bitmap}"
                              PageIndex="{Binding Index}"
                              PageWidthPt="{Binding WidthPt}"
                              PageHeightPt="{Binding HeightPt}"
                              Annotations="{Binding Annotations}"
                              PlacementCursor="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).PlacementCursor}" />
                        </Border>
                        </Border>
                        </Border>
                        <!-- Page number overlay (grid mode only) -->
                        <Border IsVisible="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).IsGridMode}"
                                Background="{DynamicResource PageNumberBadgeBrush}" CornerRadius="4" Padding="6,2"
                                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                Margin="0,0,0,6">
                          <TextBlock Text="{Binding DisplayNumber}" Foreground="{DynamicResource PageNumberForeground}"
                                     FontSize="11" FontWeight="SemiBold" />
                        </Border>
                      </Panel>

                      <!-- C1: Grid mode vertical insert-after zone -->
                      <LayoutTransformControl Grid.Column="1"
                             IsVisible="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).IsGridMode}">
                        <LayoutTransformControl.LayoutTransform>
                          <ScaleTransform
                              ScaleX="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).ButtonScale}"
                              ScaleY="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).ButtonScale}" />
                        </LayoutTransformControl.LayoutTransform>
                        <Panel Width="24" Margin="2,0,0,0">
                          <Button Classes="insert-btn"
                                  IsVisible="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).IsNotDragging}"
                                  Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).InsertPagesAfterCommand}"
                                  CommandParameter="{Binding}"
                                  ToolTip.Tip="Insert pages after">
                            <PathIcon Data="{iconr:IconGeometry Icon=plus_circle}" Foreground="{DynamicResource IconForegroundMuted}" Width="14" Height="14" />
                          </Button>
                          <Border IsVisible="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).IsDraggingFile}"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="2,4">
                            <Rectangle StrokeDashArray="4,3"
                                       Stroke="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       StrokeThickness="1.5" RadiusX="4" RadiusY="4" />
                          </Border>
                          <Border IsVisible="{Binding IsDropTargetAfter}"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                  Background="{DynamicResource AccentOverlayBrush}" CornerRadius="4" Margin="2,4">
                            <Rectangle Stroke="{DynamicResource AccentBrush}" StrokeThickness="2"
                                       StrokeDashArray="4,3" RadiusX="4" RadiusY="4" />
                          </Border>
                        </Panel>
                      </LayoutTransformControl>
                    </Grid>
                    <!-- Grid mode: left-edge drop indicator (drop before this page) -->
                    <Panel IsVisible="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).IsGridMode}" IsHitTestVisible="False">
                      <Border IsVisible="{Binding IsDropTargetBefore}"
                              Width="4" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                              Background="{DynamicResource AccentBrush}" CornerRadius="2"
                              Margin="2,6,0,6" />
                    </Panel>
                    </Panel>

                    <!-- ═══ Insert zone AFTER (list mode only) ═══ -->
                    <LayoutTransformControl IsVisible="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).IsNotGridMode}">
                      <LayoutTransformControl.LayoutTransform>
                        <ScaleTransform
                            ScaleX="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).ButtonScale}"
                            ScaleY="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).ButtonScale}" />
                      </LayoutTransformControl.LayoutTransform>
                      <Panel Height="28" Margin="0,2">
                        <Button Classes="insert-btn"
                                IsVisible="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).IsNotDragging}"
                                Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).InsertPagesAfterCommand}"
                                CommandParameter="{Binding}"
                                ToolTip.Tip="Insert pages after">
                          <PathIcon Data="{iconr:IconGeometry Icon=plus_circle}" Foreground="{DynamicResource IconForegroundMuted}" Width="16" Height="16" />
                        </Button>
                        <Border IsVisible="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).IsDraggingFile}"
                                HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="4,2">
                          <Rectangle StrokeDashArray="4,3"
                                     Stroke="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                     StrokeThickness="1.5" RadiusX="4" RadiusY="4" />
                        </Border>
                        <Border IsVisible="{Binding IsDropTargetAfter}"
                                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                Background="{DynamicResource AccentOverlayBrush}" CornerRadius="4" Margin="4,2">
                          <Rectangle Stroke="{DynamicResource AccentBrush}" StrokeThickness="2"
                                     StrokeDashArray="4,3" RadiusX="4" RadiusY="4" />
                        </Border>
                      </Panel>
                    </LayoutTransformControl>

                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </LayoutTransformControl>
        </ScrollViewer>

        <!-- Empty state overlay -->
        <Panel IsVisible="{Binding HasNoPages}"
               HorizontalAlignment="Center" VerticalAlignment="Center"
               Width="320" Height="180">
          <Rectangle StrokeDashArray="6,4"
                     Stroke="{DynamicResource SystemControlForegroundBaseLowBrush}"
                     StrokeThickness="2" RadiusX="12" RadiusY="12" />
          <StackPanel Spacing="8" Opacity="0.5"
                      HorizontalAlignment="Center" VerticalAlignment="Center">
            <PathIcon Data="{iconr:IconGeometry Icon=folder_open}"
                      Foreground="{DynamicResource IconForeground}"
                      Width="36" Height="36" HorizontalAlignment="Center" />
            <TextBlock Text="Drop a PDF here to get started"
                       FontSize="14" HorizontalAlignment="Center" />
            <TextBlock Text="or press Ctrl+O to open"
                       FontSize="11" HorizontalAlignment="Center" />
          </StackPanel>
        </Panel>
      </Panel>

    </DockPanel>

    <!-- ═══ Reusable dialog overlay ═══ -->
    <views:DialogOverlay x:Name="Dialog" />

    <!-- ═══ Inline text editor (positioned overlay) ═══ -->
    <Border x:Name="TextEditorOverlay" IsVisible="False"
            HorizontalAlignment="Left" VerticalAlignment="Top"
            Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="1" CornerRadius="6" Padding="8,6"
            BoxShadow="{DynamicResource EditorShadow}">
      <StackPanel Spacing="6">
        <TextBox x:Name="InlineTextBox" Width="200" FontSize="13"
                 PlaceholderText="Type text..." />
        <ComboBox x:Name="InlineFontCombo" Width="200" FontSize="12"
                  ItemsSource="{x:Static vm:MainViewModel.AvailableFonts}" />
      </StackPanel>
    </Border>
  </Panel>
</Window>
