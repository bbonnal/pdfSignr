<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:pdfSignr.Views.Converters"
             x:Class="pdfSignr.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <ResourceDictionary>
            <conv:ToolToCursorConverter x:Key="ToolToCursor" />
            <!-- ═══ Bundled fonts ═══ -->
            <FontFamily x:Key="LiberationSans">avares://pdfSignr/Assets/Fonts/LiberationSans-Regular.ttf#Liberation Sans</FontFamily>
            <FontFamily x:Key="LiberationSerif">avares://pdfSignr/Assets/Fonts/LiberationSerif-Regular.ttf#Liberation Serif</FontFamily>
            <FontFamily x:Key="LiberationMono">avares://pdfSignr/Assets/Fonts/LiberationMono-Regular.ttf#Liberation Mono</FontFamily>

            <!-- ═══ Theme palettes ═══ -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <!-- Surface -->
                    <SolidColorBrush x:Key="SystemControlBackgroundAltHighBrush" Color="#2C2C2C" />
                    <SolidColorBrush x:Key="SystemControlPageBackgroundChromeLowBrush" Color="#1A1A1A" />
                    <SolidColorBrush x:Key="SystemControlPageBackgroundChromeMediumLowBrush" Color="#222222" />
                    <SolidColorBrush x:Key="SystemControlForegroundBaseLowBrush" Color="#3A3A3A" />
                    <SolidColorBrush x:Key="SystemControlForegroundBaseMediumBrush" Color="#555555" />
                    <!-- Highlight -->
                    <SolidColorBrush x:Key="SystemControlHighlightListLowBrush" Color="#333333" />
                    <SolidColorBrush x:Key="SystemControlHighlightListMediumBrush" Color="#3E3E3E" />
                    <SolidColorBrush x:Key="ToggleCheckedBrush" Color="#3D4F6A" />
                    <SolidColorBrush x:Key="ToggleCheckedHoverBrush" Color="#4A5E7A" />
                    <!-- Icons -->
                    <SolidColorBrush x:Key="IconForeground" Color="#888888" />
                    <SolidColorBrush x:Key="IconForegroundMuted" Color="#AAAAAA" />
                    <!-- Accent -->
                    <SolidColorBrush x:Key="AccentBrush" Color="#3B82F6" />
                    <SolidColorBrush x:Key="AccentOverlayBrush" Color="#303B82F6" />
                    <SolidColorBrush x:Key="PageSurfaceBrush" Color="White" />
                    <SolidColorBrush x:Key="PageNumberBadgeBrush" Color="#80000000" />
                    <SolidColorBrush x:Key="PageNumberForeground" Color="White" />
                    <!-- Dialog / overlay -->
                    <SolidColorBrush x:Key="BackdropBrush" Color="#80000000" />
                    <SolidColorBrush x:Key="ErrorForeground" Color="#E06C75" />
                    <SolidColorBrush x:Key="KeyBadgeBrush" Color="#26FFFFFF" />
                    <!-- Shadows -->
                    <BoxShadows x:Key="PageShadow">0 1 6 0 #30000000</BoxShadows>
                    <BoxShadows x:Key="EditorShadow">0 4 12 0 #40000000</BoxShadows>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <!-- Surface -->
                    <SolidColorBrush x:Key="SystemControlBackgroundAltHighBrush" Color="#F3F3F3" />
                    <SolidColorBrush x:Key="SystemControlPageBackgroundChromeLowBrush" Color="#FAFAFA" />
                    <SolidColorBrush x:Key="SystemControlPageBackgroundChromeMediumLowBrush" Color="#F0F0F0" />
                    <SolidColorBrush x:Key="SystemControlForegroundBaseLowBrush" Color="#D6D6D6" />
                    <SolidColorBrush x:Key="SystemControlForegroundBaseMediumBrush" Color="#BBBBBB" />
                    <!-- Highlight -->
                    <SolidColorBrush x:Key="SystemControlHighlightListLowBrush" Color="#E8E8E8" />
                    <SolidColorBrush x:Key="SystemControlHighlightListMediumBrush" Color="#DBDBDB" />
                    <SolidColorBrush x:Key="ToggleCheckedBrush" Color="#C5D4E8" />
                    <SolidColorBrush x:Key="ToggleCheckedHoverBrush" Color="#B0C4DE" />
                    <!-- Icons -->
                    <SolidColorBrush x:Key="IconForeground" Color="#666666" />
                    <SolidColorBrush x:Key="IconForegroundMuted" Color="#888888" />
                    <!-- Accent -->
                    <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
                    <SolidColorBrush x:Key="AccentOverlayBrush" Color="#302563EB" />
                    <SolidColorBrush x:Key="PageSurfaceBrush" Color="White" />
                    <SolidColorBrush x:Key="PageNumberBadgeBrush" Color="#80000000" />
                    <SolidColorBrush x:Key="PageNumberForeground" Color="White" />
                    <!-- Dialog / overlay -->
                    <SolidColorBrush x:Key="BackdropBrush" Color="#60000000" />
                    <SolidColorBrush x:Key="ErrorForeground" Color="#C0392B" />
                    <SolidColorBrush x:Key="KeyBadgeBrush" Color="#18000000" />
                    <!-- Shadows -->
                    <BoxShadows x:Key="PageShadow">0 1 8 0 #18000000</BoxShadows>
                    <BoxShadows x:Key="EditorShadow">0 4 16 0 #22000000</BoxShadows>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- ═══ Size tokens (theme-independent) ═══ -->
            <x:Double x:Key="IconSize">20</x:Double>
            <x:Double x:Key="IconSizeSm">16</x:Double>
            <x:Double x:Key="IconSizeXs">14</x:Double>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <!-- ═══ Icon button ═══ -->
        <!-- Focusable=False so pressing Enter after a click doesn't re-invoke the button -->
        <Style Selector="Button.icon-btn">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
        </Style>
        <Style Selector="Button.icon-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}" />
        </Style>
        <Style Selector="Button.icon-btn:pressed">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListMediumBrush}" />
        </Style>
        <Style Selector="Button.icon-btn:disabled">
            <Setter Property="Opacity" Value="0.3" />
        </Style>

        <!-- ═══ Icon toggle button ═══ -->
        <Style Selector="ToggleButton.icon-btn">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
        </Style>
        <Style Selector="ToggleButton.icon-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}" />
        </Style>
        <Style Selector="ToggleButton.icon-btn:checked">
            <Setter Property="Background" Value="{DynamicResource ToggleCheckedBrush}" />
        </Style>
        <Style Selector="ToggleButton.icon-btn:checked:pointerover">
            <Setter Property="Background" Value="{DynamicResource ToggleCheckedHoverBrush}" />
        </Style>

        <!-- ═══ Flyout menu button ═══ -->
        <Style Selector="Button.flyout-btn">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.flyout-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}" />
        </Style>

        <!-- ═══ Insert-page button ═══ -->
        <Style Selector="Button.insert-btn">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Opacity" Value="0.5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="Focusable" Value="False" />
        </Style>
        <Style Selector="Button.insert-btn:pointerover">
            <Setter Property="Opacity" Value="1.0" />
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}" />
        </Style>

        <!-- ═══ Page selection border ═══ -->
        <Style Selector="Border.page-select">
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="CornerRadius" Value="2" />
        </Style>
        <Style Selector="Border.page-select.selected">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>

        <!-- ═══ Status bar button ═══ -->
        <Style Selector="Button.statusbar-btn">
            <Setter Property="Padding" Value="3,2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Opacity" Value="0.6" />
            <Setter Property="Focusable" Value="False" />
        </Style>
        <Style Selector="Button.statusbar-btn:pointerover">
            <Setter Property="Opacity" Value="1.0" />
        </Style>

        <!-- ═══ Status bar page-number input ═══ -->
        <Style Selector="TextBox.page-input">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}" />
            <Setter Property="Opacity" Value="0.75" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="2,0" />
            <Setter Property="MinHeight" Value="18" />
        </Style>
        <Style Selector="TextBox.page-input /template/ Border#PART_BorderElement">
            <Setter Property="MinHeight" Value="18" />
        </Style>
        <Style Selector="TextBox.page-input:focus">
            <Setter Property="Opacity" Value="1.0" />
        </Style>
        <Style Selector="TextBox.page-input:pointerover">
            <Setter Property="Opacity" Value="1.0" />
        </Style>
    </Application.Styles>
</Application>
