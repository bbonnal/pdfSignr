            <StreamGeometry x:Key="IconCaretDown">M216.49,104.49l-80,80a12,12,0,0,1-17,0l-80-80a12,12,0,0,1,17-17L128,159l71.51-71.52a12,12,0,0,1,17,17Z</StreamGeometry>

            <!-- Theme palettes -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="SystemControlBackgroundAltHighBrush" Color="#2C2C2C" />
                    <SolidColorBrush x:Key="SystemControlPageBackgroundChromeLowBrush" Color="#1A1A1A" />
                    <SolidColorBrush x:Key="SystemControlPageBackgroundChromeMediumLowBrush" Color="#222222" />
                    <SolidColorBrush x:Key="SystemControlForegroundBaseLowBrush" Color="#3A3A3A" />
                    <SolidColorBrush x:Key="SystemControlHighlightListLowBrush" Color="#333333" />
                    <SolidColorBrush x:Key="SystemControlHighlightListMediumBrush" Color="#3E3E3E" />
                    <SolidColorBrush x:Key="ToggleCheckedBrush" Color="#3D4F6A" />
                    <SolidColorBrush x:Key="ToggleCheckedHoverBrush" Color="#4A5E7A" />
                    <SolidColorBrush x:Key="ReorderBtnBrush" Color="#80000000" />
                    <SolidColorBrush x:Key="ReorderBtnHoverBrush" Color="#A0000000" />
                    <SolidColorBrush x:Key="IconForeground" Color="#888888" />
                    <SolidColorBrush x:Key="IconForegroundMuted" Color="#AAAAAA" />
                    <SolidColorBrush x:Key="IconForegroundBright" Color="#DDDDDD" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="SystemControlBackgroundAltHighBrush" Color="#F3F3F3" />
                    <SolidColorBrush x:Key="SystemControlPageBackgroundChromeLowBrush" Color="#FAFAFA" />
                    <SolidColorBrush x:Key="SystemControlPageBackgroundChromeMediumLowBrush" Color="#F0F0F0" />
                    <SolidColorBrush x:Key="SystemControlForegroundBaseLowBrush" Color="#D6D6D6" />
                    <SolidColorBrush x:Key="SystemControlHighlightListLowBrush" Color="#E8E8E8" />
                    <SolidColorBrush x:Key="SystemControlHighlightListMediumBrush" Color="#DBDBDB" />
                    <SolidColorBrush x:Key="ToggleCheckedBrush" Color="#C5D4E8" />
                    <SolidColorBrush x:Key="ToggleCheckedHoverBrush" Color="#B0C4DE" />
                    <SolidColorBrush x:Key="ReorderBtnBrush" Color="#40000000" />
                    <SolidColorBrush x:Key="ReorderBtnHoverBrush" Color="#60000000" />
                    <SolidColorBrush x:Key="IconForeground" Color="#666666" />
                    <SolidColorBrush x:Key="IconForegroundMuted" Color="#888888" />
                    <SolidColorBrush x:Key="IconForegroundBright" Color="#444444" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <!-- Icon button -->
        <Style Selector="Button.icon-btn">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.icon-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}" />
        </Style>
        <Style Selector="Button.icon-btn:pressed">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListMediumBrush}" />
        </Style>
        <Style Selector="Button.icon-btn:disabled">
            <Setter Property="Opacity" Value="0.3" />
        </Style>

        <!-- Icon toggle button -->
        <Style Selector="ToggleButton.icon-btn">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="ToggleButton.icon-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}" />
        </Style>
        <Style Selector="ToggleButton.icon-btn:checked">
            <Setter Property="Background" Value="{DynamicResource ToggleCheckedBrush}" />
        </Style>
        <Style Selector="ToggleButton.icon-btn:checked:pointerover">
            <Setter Property="Background" Value="{DynamicResource ToggleCheckedHoverBrush}" />
        </Style>

        <!-- Flyout menu button -->
        <Style Selector="Button.flyout-btn">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.flyout-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}" />
        </Style>

        <!-- Insert-page button -->
        <Style Selector="Button.insert-btn">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Opacity" Value="0.5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="MinWidth" Value="40" />
        </Style>
        <Style Selector="Button.insert-btn:pointerover">
            <Setter Property="Opacity" Value="1.0" />
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}" />
        </Style>

        <!-- Reorder-page button -->
        <Style Selector="Button.reorder-btn">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{DynamicResource ReorderBtnBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.reorder-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource ReorderBtnHoverBrush}" />
        </Style>
    </Application.Styles>
</Application>
